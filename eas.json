{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "apk": {
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://unified-backend.vercel.app/api/v1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "credentialsSource": "local",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://unified-backend.vercel.app/api/v1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
